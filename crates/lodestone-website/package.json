{
  "name": "lodestone_website",
  "private": true,
  "version": "0.0.0",
  "description": "Lodestone — A modern Minecraft launcher website",
  "author": "",
  "license": "GPL-3.0-or-later",
  "repository": "",
  "type": "module",
  "scripts": {
    "build-api": "cargo build --release",
    "run-api": "cargo run --bin lodestone_website",
    "dev": "vite",
    "build-frontend": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "watch": "cargo watch -x \"run --bin lodestone_website\" -C dist -N --why -w ../src-actix/",
    "build": "npm run \"build-frontend\" && npm run \"build-api\""
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.26",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "8.21.0",
    "@typescript-eslint/parser": "8.21.0",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.16",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.18",
    "postcss": "8.4.31",
    "postcss-import": "15.1.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "vite": "6.3.6"
  }
}
